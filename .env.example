# ── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed frontend origins (CORS)
CLIENT_ORIGIN=http://localhost:5173

# ── Database (Supabase Postgres) ───────────────────────
# Pooled connection (runtime) — port 6543 with pgbouncer
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (migrations) — port 5432
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# ── Cloudinary ─────────────────────────────────────────
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret
CLOUDINARY_PRESET=blogcraft_unsigned
